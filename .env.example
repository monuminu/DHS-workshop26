# ============================================================================
#  DHS Workshop 2026 — Agentic AI with Microsoft Agent Framework
#  Copy this file to `.env` and fill in the values for the provider you choose.
#    cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
#  1) PICK YOUR MODEL BACKEND
#  This single variable decides which model every notebook runs against.
#  Options: foundry | openai | azure-openai | anthropic | ollama | bedrock | gemini
# ----------------------------------------------------------------------------
MODEL_PROVIDER=foundry


# ----------------------------------------------------------------------------
#  2) FILL IN THE SECTION FOR YOUR CHOSEN PROVIDER (leave the others blank)
# ----------------------------------------------------------------------------

# --- foundry (DEFAULT) — Azure AI Foundry -----------------------------------
# Auth uses Azure CLI: run `az login` first (no key needed here).
FOUNDRY_PROJECT_ENDPOINT="https://your-project.services.ai.azure.com/api/projects/your-project"
FOUNDRY_MODEL="gpt-4o"

# --- openai — OpenAI platform -----------------------------------------------
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
# OPENAI_BASE_URL="https://api.openai.com/v1/"     # only if using a proxy

# --- azure-openai — Azure OpenAI --------------------------------------------
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_API_KEY=""                            # leave blank to use `az login` (Entra ID)
AZURE_OPENAI_API_VERSION="2024-10-21"
AZURE_OPENAI_MODEL="gpt-4o"                        # your deployment name

# --- anthropic — Anthropic Claude  (uv pip install -e ".[anthropic]") -------
ANTHROPIC_API_KEY=""
ANTHROPIC_CHAT_MODEL="claude-sonnet-4-5-20250929"

# --- ollama — local models, no API key  (uv pip install -e ".[ollama]") -----
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"

# --- bedrock — AWS Bedrock  (uv pip install -e ".[bedrock]") -----------------
BEDROCK_REGION="us-east-1"
BEDROCK_CHAT_MODEL="anthropic.claude-3-5-sonnet-20241022-v2:0"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# AWS_SESSION_TOKEN=""

# --- gemini — Google Gemini via its OpenAI-compatible endpoint --------------
# Agent Framework has no native Gemini client; we point the OpenAI client at
# Gemini's OpenAI-compatible API.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"


# ----------------------------------------------------------------------------
#  3) OPTIONAL — Observability (used in Module 07)
#  Point at any OTLP collector (e.g. a local Aspire dashboard or Jaeger).
# ----------------------------------------------------------------------------
# ENABLE_OTEL=true
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
